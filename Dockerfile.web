# ── Stage 1: build the SPA ──────────────────────────────────────────────
FROM node:20-alpine AS spa
WORKDIR /spa

# Copy manifest first for cacheable dep install
COPY src/MemoryBank.Web/ClientApp/package.json src/MemoryBank.Web/ClientApp/package-lock.json* ./
RUN npm ci

COPY src/MemoryBank.Web/ClientApp/ ./
RUN npm run build

# ── Stage 2: build the .NET backend ─────────────────────────────────────
FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src

COPY Directory.Build.props .
COPY src/MemoryBank.Core/MemoryBank.Core.csproj src/MemoryBank.Core/
COPY src/MemoryBank.Web/MemoryBank.Web.csproj src/MemoryBank.Web/
RUN dotnet restore src/MemoryBank.Web/MemoryBank.Web.csproj

COPY src/MemoryBank.Core/ src/MemoryBank.Core/
COPY src/MemoryBank.Web/ src/MemoryBank.Web/

# Drop the pre-built SPA into wwwroot; MSBuild will pick it up via
# IncludePrebuiltClientApp when SkipClientAppBuild=true is set.
COPY --from=spa /spa/dist/ src/MemoryBank.Web/wwwroot/

RUN dotnet publish src/MemoryBank.Web/MemoryBank.Web.csproj \
    -c Release -o /app/publish \
    /p:SkipClientAppBuild=true

# ── Stage 3: runtime ────────────────────────────────────────────────────
FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS runtime
WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/* \
    && mkdir -p /data/memorybank

COPY --from=build /app/publish .

ENV ASPNETCORE_URLS=http://0.0.0.0:5174
ENV MemoryBank__Database__Path=/data/memorybank/memorybank.db
ENV MemoryBank__Backup__Path=/data/memorybank/backups
ENV MemoryBank__Logging__FilePath=/data/memorybank/logs/memorybank.log

EXPOSE 5174

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD curl -f http://localhost:5174/api/filters || exit 1

ENTRYPOINT ["dotnet", "MemoryBank.Web.dll"]
