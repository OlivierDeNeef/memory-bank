{
  "name": "deepmind",
  "description": "DeepMind - Persistent memory system for AI assistants. Recall, remember, forget, and search your second mind via slash commands.",
  "version": "1.0.0",
  "author": {
    "name": "Olivier de Neef"
  },
  "license": "MIT",
  "keywords": [
    "memory",
    "recall",
    "knowledge",
    "mcp",
    "semantic-search",
    "second-mind"
  ],
  "skills": "./skills/",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__deepmind__*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/block-direct-mcp.sh"
          }
        ]
      }
    ]
  }
}
