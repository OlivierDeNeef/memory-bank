# Copy to .env and fill in real values. Never commit .env.
#
# Generate the password hash with:
#   dotnet run --project src/MemoryBank.Server -- --hash-password 'your-password'

MEMORYBANK_AUTH_USERNAME=admin
MEMORYBANK_AUTH_PASSWORD_HASH=pbkdf2-sha256$100000$REPLACE_ME$REPLACE_ME

# Optional: only needed for dev runs where the viewer (5174) and MCP server (6868)
# are on different hosts. In production, both are routed under one nginx host so
# the viewer derives the auth URL from the request and this stays empty.
# MEMORYBANK_AUTH_BASE_URL=http://localhost:6868
